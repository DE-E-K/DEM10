{
  "uid": "heartbeat-overview-v2",
  "id": 1,
  "title": "Heartbeat Monitoring Overview",
  "description": "Real-time customer heartbeat pipeline – events, anomalies, and system health",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "tags": [
    "heartbeat",
    "realtime",
    "kafka",
    "postgres",
    "flink"
  ],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heartbeats Ingested per Minute",
      "description": "Count of valid heartbeat events written to PostgreSQL each minute. Drops indicate consumer lag or DB pressure.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', event_time) AS time, count(*)::double precision AS value FROM heartbeat_events WHERE $__timeFilter(event_time) GROUP BY 1 ORDER BY 1",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Anomalies Detected per Minute",
      "description": "Count of anomalous readings (LOW, HIGH, SPIKE) detected each minute. Sustained elevation warrants investigation.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('minute', event_time) AS time, count(*)::double precision AS value FROM anomalies WHERE $__timeFilter(event_time) GROUP BY 1 ORDER BY 1",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Anomaly Breakdown by Type",
      "description": "Distribution of anomaly types within the selected time range. HIGH_HEART_RATE and LOW_HEART_RATE are severity=high; SPIKE is severity=medium.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT anomaly_type, count(*) AS count FROM anomalies WHERE $__timeFilter(event_time) GROUP BY anomaly_type ORDER BY count DESC",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Average Heart Rate",
      "description": "Population-wide mean heart rate across all customers in the selected time range.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT round(avg(heart_rate)::numeric, 1)::double precision AS value FROM heartbeat_events WHERE $__timeFilter(event_time)",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Avg BPM",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 60
              },
              {
                "color": "orange",
                "value": 120
              },
              {
                "color": "red",
                "value": 140
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "p95 Heart Rate",
      "description": "95th percentile heart rate — the threshold below which 95% of readings fall. High values indicate widespread elevated activity.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT percentile_cont(0.95) WITHIN GROUP (ORDER BY heart_rate)::double precision AS value FROM heartbeat_events WHERE $__timeFilter(event_time)",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "p95 BPM",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 130
              },
              {
                "color": "red",
                "value": 160
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active Customers",
      "description": "Number of distinct customers who sent at least one reading in the selected time range. Sudden drops may indicate producer or Kafka issues.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT count(DISTINCT customer_id)::double precision AS value FROM heartbeat_events WHERE $__timeFilter(event_time)",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Active Customers"
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent Anomalies",
      "description": "The 20 most recent anomaly records. Use this panel to quickly identify which customers triggered alerts.",
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "PCC52D03280B7034C"
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT event_time, customer_id, heart_rate, anomaly_type, severity FROM anomalies ORDER BY event_time DESC LIMIT 20",
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "PCC52D03280B7034C"
          }
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      }
    },
    {
      "id": 8,
      "type": "row",
      "title": "Flink Cluster Health",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Flink Records In / Out per Second",
      "description": "Records flowing through Flink operators. A sustained gap between in and out indicates processing bottleneck or data loss.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(flink_taskmanager_job_task_numRecordsIn[1m])",
          "legendFormat": "Records In ({{task_name}})"
        },
        {
          "refId": "B",
          "expr": "rate(flink_taskmanager_job_task_numRecordsOut[1m])",
          "legendFormat": "Records Out ({{task_name}})"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Flink Checkpoint Duration",
      "description": "Time taken to complete each Flink checkpoint. Spikes indicate state-backend or I/O pressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "flink_jobmanager_job_lastCheckpointDuration / 1000",
          "legendFormat": "Checkpoint Duration (s)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Flink Uptime",
      "description": "Time since the Flink JobManager started. Restarts reset this counter.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "flink_jobmanager_job_uptime / 1000",
          "legendFormat": "Uptime"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "displayName": "Job Uptime"
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Completed Checkpoints",
      "description": "Total number of successfully completed Flink checkpoints since job start.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "flink_jobmanager_job_numberOfCompletedCheckpoints",
          "legendFormat": "Completed"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Checkpoints OK"
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Failed Checkpoints",
      "description": "Number of failed checkpoints. Non-zero values indicate state-backend or configuration issues.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "flink_jobmanager_job_numberOfFailedCheckpoints",
          "legendFormat": "Failed"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "Checkpoints Failed",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "type": "gauge",
      "title": "Flink Task Slots Used",
      "description": "Number of task slots currently in use vs. total available. Saturation means no capacity for additional parallelism.",
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "flink_jobmanager_numRegisteredTaskManagers",
          "legendFormat": "TaskManagers"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "TaskManagers"
        }
      }
    }
  ]
}