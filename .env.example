# .env.example: Copy this file to .env and fill in real values
#
#   Copy-Item .env.example .env   (PowerShell)
#   cp .env.example .env          (Linux / macOS)
#
# NEVER commit .env to version control — it is listed in .gitignore.
# ===========================================================================

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TOPIC_RAW=events.raw.v1
KAFKA_TOPIC_INVALID=events.invalid.v1
KAFKA_TOPIC_ANOMALY=events.anomaly.v1
KAFKA_TOPIC_DLQ=events.dlq.v1
KAFKA_CONSUMER_GROUP_DB=cg.db-writer.v1
KAFKA_CONSUMER_GROUP_ANOMALY=cg.anomaly.v1

# PostgreSQL (REQUIRED — no defaults in code)
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=heartbeat
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10

# Grafana (REQUIRED — no defaults in code)
GF_ADMIN_USER=CHANGE_ME
GF_ADMIN_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# Simulation
SIM_CUSTOMER_COUNT=1000
SIM_EVENTS_PER_SECOND=200
SIM_BURST_MULTIPLIER=4
SIM_SLEEP_SECONDS=0.2
SIM_INVALID_RATIO=0.02
SIM_DYNAMIC_CUSTOMERS=false
SIM_ACTIVE_CUSTOMERS_MIN=200
SIM_ACTIVE_CUSTOMERS_MAX=1000
SIM_ACTIVE_CUSTOMERS_REFRESH_PROBABILITY=0.03

# Heart-rate domain bounds
HEART_RATE_MIN=45
HEART_RATE_MAX=185

# Anomaly detection thresholds
ANOMALY_LOW_THRESHOLD=50
ANOMALY_HIGH_THRESHOLD=140
ANOMALY_SPIKE_DELTA=30

# Observability
LOG_LEVEL=INFO
PROMETHEUS_PORT=8000
